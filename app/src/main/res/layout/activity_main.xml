<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Logo IFSC -->
    <ImageView
        android:id="@+id/imageViewLogo"
        android:layout_width="200dp"
        android:layout_height="120dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/ifsc"
        android:contentDescription="Logo IFSC"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Ícone -->
    <ImageView
        android:id="@+id/imageViewNoticia"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/noticia"
        android:contentDescription="Notícia"
        app:layout_constraintTop_toBottomOf="@id/imageViewLogo"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Título -->
    <TextView
        android:id="@+id/textTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOTÍCIAS RECENTES"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/imageViewNoticia"
        app:layout_constraintTop_toTopOf="@id/imageViewNoticia"
        app:layout_constraintBottom_toBottomOf="@id/imageViewNoticia" />

    <!-- Linha -->
    <View
        android:id="@+id/divisor"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/imageViewNoticia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Curso -->
    <TextView
        android:id="@+id/textCurso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Curso ofertado:"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/divisor"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textNomeCurso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FIC Inglês"
        android:layout_marginStart="8dp"
        app:layout_constraintBaseline_toBaselineOf="@id/textCurso"
        app:layout_constraintStart_toEndOf="@id/textCurso"/>

    <!-- Área -->
    <TextView
        android:id="@+id/textArea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Área:"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/textCurso"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textAreaValor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Qualificação Profissional"
        android:layout_marginStart="8dp"
        app:layout_constraintBaseline_toBaselineOf="@id/textArea"
        app:layout_constraintStart_toEndOf="@id/textArea"/>

    <!-- Data -->
    <TextView
        android:id="@+id/textInscricao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inscrições até:"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/textArea"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/textData"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="08/03/2024"
        android:layout_marginStart="8dp"
        app:layout_constraintBaseline_toBaselineOf="@id/textInscricao"
        app:layout_constraintStart_toEndOf="@id/textInscricao"/>

    <!-- Botão -->
    <Button
        android:id="@+id/buttonInscrever"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="QUERO ME INSCREVER"
        app:layout_constraintTop_toBottomOf="@id/textInscricao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Barra inferior -->
    <LinearLayout
        android:id="@+id/menuInferior"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="4"
        android:background="#EEEEEE"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/imageButton1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/tela_inicial"
            android:background="@android:color/transparent"
            android:contentDescription="Início"/>

        <ImageButton
            android:id="@+id/imageButton2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/outline_contact_support_24"
            android:background="@android:color/transparent"
            android:contentDescription="Contato"/>

        <ImageButton
            android:id="@+id/imageButton3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/ajuda"
            android:background="@android:color/transparent"
            android:contentDescription="Ajuda"/>

        <ImageButton
            android:id="@+id/imageButton4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@drawable/jornal"
            android:background="@android:color/transparent"
            android:contentDescription="Notícias"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>