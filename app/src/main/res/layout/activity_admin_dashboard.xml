<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="140dp"
        android:layout_height="80dp"
        android:src="@drawable/ifsc"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Painel Administrativo"
        android:textStyle="bold"
        android:textSize="26sp"
        android:layout_marginTop="20dp"/>

    <Button
        android:id="@+id/btnNovoCurso"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Publicar Curso"
        android:layout_marginTop="40dp"/>

    <Button
        android:id="@+id/btnNovaNoticia"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Publicar Notícia"
        android:layout_marginTop="20dp"/>

    <Button
        android:id="@+id/btnGerenciar"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Gerenciar Publicações"
        android:layout_marginTop="20dp"/>

</LinearLayout>